// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ─── MRW Pro Models ────────────────────────────────────

model MrwCredentials {
  id                  String   @id @default(cuid())
  shop                String   @unique
  codigoFranquicia    String
  codigoAbonado       String
  codigoDepartamento  String   @default("")
  username            String
  password            String
  verified            Boolean  @default(false)
  verifiedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ShippingConfig {
  id                  String   @id @default(cuid())
  shop                String   @unique
  defaultService      String   @default("0800")
  defaultWeight       Int      @default(2)
  defaultLength       Int      @default(30)
  defaultWidth        Int      @default(20)
  defaultHeight       Int      @default(15)
  autoCreateShipment  Boolean  @default(true)
  sendTrackingEmail   Boolean  @default(true)
  sendTrackingSms     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Shipment {
  id                  String   @id @default(cuid())
  shop                String
  shopifyOrderId      String
  shopifyOrderName    String
  customerName        String
  customerPhone       String   @default("")
  destinationAddress  String
  destinationCity     String
  destinationZip      String
  destinationProvince String   @default("")
  mrwTrackingNumber   String?
  mrwServiceCode      String   @default("0800")
  weight              Int      @default(1)
  packages            Int      @default(1)
  status              String   @default("PENDING")
  labelPdf            String?
  reference           String?
  observations        String   @default("")
  error               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  events              ShipmentEvent[]

  @@index([shop])
  @@index([shopifyOrderId])
  @@index([mrwTrackingNumber])
  @@index([status])
}

model ShipmentEvent {
  id            String   @id @default(cuid())
  shipmentId    String
  status        String
  description   String
  location      String   @default("")
  eventDate     DateTime
  createdAt     DateTime @default(now())

  shipment      Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId])
}

model Pickup {
  id            String   @id @default(cuid())
  shop          String
  date          DateTime
  timeSlot      String
  packages      Int      @default(1)
  notes         String   @default("")
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([shop])
}

model ReturnShipment {
  id                  String   @id @default(cuid())
  shop                String
  originalShipmentId  String?
  shopifyOrderId      String   @default("")
  shopifyOrderName    String   @default("")
  customerName        String
  customerPhone       String   @default("")
  pickupAddress       String
  pickupCity          String
  pickupZip           String
  pickupProvince      String   @default("")
  mrwTrackingNumber   String?
  mrwServiceCode      String   @default("0800")
  reason              String   @default("")
  status              String   @default("PENDING")
  error               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([shop])
  @@index([originalShipmentId])
  @@index([status])
}

// ─── Phase 3A: Shipping Rules ──────────────────────────

model ShippingRule {
  id                  String   @id @default(cuid())
  shop                String
  name                String
  conditionField      String   // weight, total, postalCode, province, tags
  conditionOperator   String   // gte, lte, gt, lt, eq, contains, startsWith
  conditionValue      String
  actionService       String   // MRW service code
  actionInsurance     Boolean  @default(false)
  enabled             Boolean  @default(true)
  priority            Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([shop])
  @@index([shop, enabled, priority])
}

// ─── Phase 3A: Branded Tracking ────────────────────────

model TrackingConfig {
  id                  String   @id @default(cuid())
  shop                String   @unique
  logoUrl             String?
  primaryColor        String   @default("#E30613") // MRW red
  secondaryColor      String   @default("#1A1A2E")
  accentColor         String   @default("#10B981")
  showStoreName       Boolean  @default(true)
  storeName           String?
  customCss           String?
  footerText          String?
  showPoweredBy       Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── Phase 3A: Notification Config ─────────────────────

model NotificationConfig {
  id                    String   @id @default(cuid())
  shop                  String   @unique
  smsEnabled            Boolean  @default(false)
  whatsappEnabled       Boolean  @default(false)
  // Twilio SMS
  twilioSid             String   @default("")
  twilioToken           String   @default("")
  twilioFromNumber      String   @default("")
  // WAHA WhatsApp
  wahaUrl               String   @default("")
  wahaApiKey            String   @default("")
  wahaSession           String   @default("default")
  // Per-event toggles
  notifyOnCreated       Boolean  @default(true)
  notifyOnPickedUp      Boolean  @default(false)
  notifyOnInTransit     Boolean  @default(true)
  notifyOnOutForDelivery Boolean @default(true)
  notifyOnDelivered     Boolean  @default(true)
  notifyOnIncident      Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
